# ─────────────────────────────────────────────────────────
#  ZION LOPES PORTFOLIO — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ── Email (Nodemailer) ────────────────────────────────────
# For Gmail: use an App Password (not your real password).
# Go to: Google Account → Security → 2-Step Verification → App Passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-app-password-here

# The email address that receives contact form submissions
CONTACT_RECEIVER=your-email@gmail.com

# The "From" name shown in the received email
MAIL_FROM_NAME=Zion Portfolio

# ── Security ──────────────────────────────────────────────
# Any random secret string (used for CORS / future JWT)
SECRET=change-this-to-something-random

# ── Frontend origin (for CORS) ────────────────────────────
# In development: http://localhost:3000
# In production: https://zionlopes.vercel.app
FRONTEND_ORIGIN=http://localhost:3000
